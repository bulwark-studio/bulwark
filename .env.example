# Bulwark Configuration
# Copy to .env and fill in your values

# Server
MONITOR_PORT=3001
MONITOR_USER=admin
MONITOR_PASS=changeme

# PostgreSQL (optional — app works without it)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# VPS_DATABASE_URL=postgresql://user:password@host:5432/dbname

# Repository root for Git/Deploy operations (defaults to cwd)
# REPO_DIR=/path/to/your/repo

# Product name (shown in UI, login page, terminal banner)
# APP_NAME=Bulwark

# Node environment
# NODE_ENV=production
